<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-with,initial-scale=1,viewport-fit=cover">
    <title>LongGambit</title>
    <link rel="stylesheet" href="style.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f4f4f4;
        }

        header {
            background: white;
            color: black;
            padding: 15px;
            right: center;
        }

        nav {
            background: #555;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 0 10px;
            text-decoration: none;
        }
    </style>
    <header>
        <p>LongGambit</p>
    </header>
    <nav>
        <button onclick="hientrangchu">Từ vựng</button>
        <button onclick="hientrangchu">Ngữ pháp</button>
        <button onclick="hientrangchu">phrasal verbs</button>
        <button onclick="hientrangchu">chia thì</button>
        <p id="ketqua"></p>
    </nav>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <div class="container">
        <div class="row text-center">
            <div class="col-6 col-md-3">
                <div class="rounded p-3">
                    <button class="#" onclick="showN5()">Danh từ N5</button>
                    <div id="n5box" class="card mt-3 d-none" style="width:300px">
                        <div class="N5-card">
                            <button class="btn-close float-end" onclick="closeBox()"></button>
                            <h6>Danh từ N5</h6>

                            <ul>
                                <li>学校 (trường học)</li>
                                <li>先生 (giáo viên)</li>
                                <li>学生 (học sinh)</li>
                                <li>友達 (bạn bè)</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rounded p-3">
                        <button class="#">Danh từ N4</button>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rounded p-3">
                        <button class="#" onclick="">Danh từ N3</button>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rounded p-3">
                        <button class="#">Danh từ N2</button>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="rounded p-3">
                        <button class="#">Danh từ N1</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <div class="lang-bar">
        <button onclick="prev()">←</button>
        <span id="text">日本語</span>
        <button onclick="change()">→</button>
    </div>

    <script src="script.js"></script>
</head>

</html>
